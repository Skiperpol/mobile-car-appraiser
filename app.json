{
  "expo": {
    "name": "mobile-car-appraiser",
    "slug": "mobile-car-appraiser",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "mobilecarappraiser",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.mobilecarappraiser",
      "infoPlist": {
        "NSCameraUsageDescription": "Aplikacja potrzebuje dostepu do kamery do skanowania kodow Aztec."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/assets/images/android-icon-foreground.png",
        "backgroundImage": "./src/assets/images/android-icon-background.png",
        "monochromeImage": "./src/assets/images/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "permissions": ["CAMERA"],
      "package": "com.anonymous.mobilecarappraiser"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Aplikacja potrzebuje dostepu do kamery do skanowania kodow Aztec."
        }
      ]
    ],
    "extra": {
      "lastUpdateAt": "2026-04-22"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
